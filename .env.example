# .env.example – Umgebungsvariablen für das Seamless Failover Setup
# Kopiere diese Datei nach .env und ersetze alle Platzhalter.
# ACHTUNG: Die .env-Datei darf NICHT in die Versionskontrolle eingecheckt werden!

# RCON-Passwort für Minecraft-Server (wird von Watchdog und Admin-Skripten benötigt)
RCON_PASSWORD=changeme_rcon_password

# Redis-Passwort (optional, muss in redis/redis.conf gesetzt werden)
# REDIS_PASSWORD=changeme_redis_password

# HAProxy Stats-Passwort
# HAPROXY_STATS_PASSWORD=changeme_stats_password
