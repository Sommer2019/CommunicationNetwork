# ==============================================================================
# config.env  –  THE ONE FILE TO EDIT
# ==============================================================================
# After editing, run:
#   ./deploy.sh
# Then copy / rsync the generated dist/node-a  dist/node-b  dist/witness
# folders to the corresponding machines and run install.sh on each.
# ==============================================================================

# ── Node IPs (physical / static addresses) ────────────────────────────────────
NODE_A_IP="192.168.1.101"       # Node A – real IP (not the floating IP)
NODE_B_IP="192.168.1.102"       # Node B – real IP
WITNESS_IP="203.0.113.20"       # Witness server – public or private IP

# ── Floating-IP / VIP (players always connect here) ───────────────────────────
FLOATING_IP="203.0.113.10"

# ── Network interface on Node A and Node B (run: ip a) ────────────────────────
NIC="eth0"

# ── Keepalived VRRP ───────────────────────────────────────────────────────────
VRRP_ROUTER_ID="51"             # 1–255; arbitrary but unique on your LAN
VRRP_AUTH_PASS="ChangeMe!HA"    # max 8 chars for PASS type; SAME on both nodes
NODE_A_PRIORITY="110"           # higher = preferred master
NODE_B_PRIORITY="90"

# ── Minecraft / Velocity ports ────────────────────────────────────────────────
PROXY_PORT="25565"              # Velocity listen port (players connect here)
SURVIVAL_PORT="25570"           # Paper backend – survival world
LOBBY_PORT="25571"              # Paper backend – lobby
CREATIVE_PORT="25572"           # Paper backend – creative

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PORT="6379"
REDIS_PASSWORD="ChangeMe!Redis" # strong password; SAME on both nodes

# ── Quorum Witness ────────────────────────────────────────────────────────────
WITNESS_PORT="8080"
# "allow"  – if witness unreachable, both nodes may run (prefers availability)
# "deny"   – if witness unreachable, no node starts  (prefers consistency)
QUORUM_SAFE_MODE="allow"

# ── GlusterFS world volume ────────────────────────────────────────────────────
WORLD_MOUNT="/mnt/minecraft/worlds"
GLUSTER_VOLUME="worlds"

# ── Velocity / Paper forwarding secret ────────────────────────────────────────
# Generate a new value:  python3 -c "import secrets; print(secrets.token_hex(32))"
VELOCITY_FORWARDING_SECRET="ChangeMe!VelocitySecretPleaseReplaceThis00000000"

# ── MySQL / MariaDB (used by HuskSync for persistent storage) ─────────────────
MYSQL_HOST="127.0.0.1"          # shared DB host, or 127.0.0.1 with Galera
MYSQL_PORT="3306"
MYSQL_DATABASE="husksync"
MYSQL_USER="husksync"
MYSQL_PASSWORD="ChangeMe!MySQL"

# ── Ops notification e-mail (keepalived alerts) ───────────────────────────────
OPS_EMAIL="ops@example.com"
